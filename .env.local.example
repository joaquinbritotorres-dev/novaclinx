# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA subas .env.local a GitHub.

# ─── Server-only (NUNCA usar prefijo NEXT_PUBLIC_ aquí) ──────────────────────

# Obtener en: platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXX

# Obtener en: console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-XXX

# Obtener en: supabase.com → tu proyecto → Settings → API → service_role key
# NUNCA exponer con prefijo NEXT_PUBLIC_ — tiene acceso total sin RLS
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Obtener en: supabase.com → tu proyecto → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=tu-jwt-secret-aqui

# Dátil — facturación electrónica SRI Ecuador (datil.dev)
# ambiente: 1 = pruebas | 2 = producción
DATIL_API_KEY=tu-api-key-de-datil
DATIL_AMBIENTE=1
DATIL_CERT_PASSWORD=tu-password-del-certificado-firma

# Dátil Emisor - Datos de quien emite la factura (tu negocio/consultorio)
DATIL_EMISOR_RUC=0000000000000
DATIL_EMISOR_RAZON_SOCIAL="Nombre de tu Razón Social"
DATIL_EMISOR_NOMBRE_COMERCIAL="Nombre de tu Nombre Comercial"
DATIL_EMISOR_DIRECCION="Dirección de tu establecimiento"
DATIL_EMISOR_OBLIGADO_CONTABILIDAD=false
DATIL_EMISOR_CONTRIBUYENTE_ESPECIAL=""
DATIL_EMISOR_ESTAB_CODIGO="001"
DATIL_EMISOR_PUNTO_EMISION="001"

# ─── Públicas (seguras para el browser — RLS protege los datos) ──────────────

# Obtener en: supabase.com → tu proyecto → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://XXX.supabase.co

# Obtener en: supabase.com → tu proyecto → Settings → API → anon public key
# Es público y seguro para el browser porque RLS lo protege a nivel de base de datos
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# URL base de la app (cambiar a tu dominio en producción)
NEXT_PUBLIC_APP_URL=http://localhost:3000
