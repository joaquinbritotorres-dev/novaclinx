# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA subas .env.local a GitHub.

# ─── Server-only (NUNCA usar prefijo NEXT_PUBLIC_ aquí) ──────────────────────

# IA clínica (notas SOAP + condensado de grabaciones). Modelo: Claude.
# Obtener en: console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-XXX

# Supabase service role — acceso total sin RLS. NUNCA exponer con NEXT_PUBLIC_.
# Obtener en: supabase.com → tu proyecto → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase JWT secret (verificación de tokens).
# Obtener en: supabase.com → tu proyecto → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=tu-jwt-secret-aqui

# Facturación electrónica SRI (AutorizadorEC). Account Key de la plataforma.
# El Company Key (sk_) de cada médico se guarda cifrado en Supabase Vault.
AUTORIZADOREC_ACCOUNT_KEY=ak_test_xxx

# Transcripción de audio de consultas (scribe de voz).
# Obtener en: console.deepgram.com
DEEPGRAM_API_KEY=dg_xxx

# Clave para cifrar (AES-256-GCM) la contraseña del certificado .p12 de firma.
# Generar 32 bytes hex, p. ej.: openssl rand -hex 32
FIRMA_ENCRYPTION_KEY=generate-a-32-byte-hex-key

# Secreto del cron de sincronización de facturas (header Authorization: Bearer).
# Generar aleatorio, p. ej.: openssl rand -hex 32
CRON_SECRET=generate-a-random-secret

# PayPhone (cobro con tarjeta) — NO implementado aún.
# PAYPHONE_TOKEN=
# PAYPHONE_STORE_ID=

# ─── Públicas (seguras para el browser — RLS protege los datos) ──────────────

# Obtener en: supabase.com → tu proyecto → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://XXX.supabase.co

# Obtener en: supabase.com → tu proyecto → Settings → API → anon public key
# Es público y seguro para el browser porque RLS lo protege a nivel de base de datos
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# URL base de la app (cambiar a tu dominio en producción)
NEXT_PUBLIC_APP_URL=http://localhost:3000
